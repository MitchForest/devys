               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "TGT001"
                     BuildableName = "Devys.app"
                     BlueprintName = "mac-client"
                     ReferencedContainer = "container:Devys.xcodeproj">
                  </BuildableReference>
