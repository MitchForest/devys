<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled to allow terminal/shell process spawning -->
	<!-- Required for running AI coding agents (Claude Code, Codex) and CLI tools -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
